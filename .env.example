# Upstage Solar Embedding API
UPSTAGE_API_KEY=up_xxxxxxxxxxxx

# Qdrant (local docker-compose default)
QDRANT_URL=http://localhost:6333
# 로컬 docker-compose 는 인증 불필요 — 빈 값 유지.
# 원격 Qdrant Cloud 사용 시 실제 API key 주입 (컨테이너 외부 노출이므로 반드시 설정).
QDRANT_API_KEY=

